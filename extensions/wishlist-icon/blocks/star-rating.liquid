<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div
  class="wishlist-button wishlist-button-{{section.id}} wishlist"
  x-data="wishlist"
>
  <button type="button" @click.debounce="addToWishlist()">
    <svg
      class="wishlist-inspire__icon--svg"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="#000"
      :fill="wishlisted ? '#000': '#fff' "
    >
      <path d="M12 21.35l-1.45-1.32C5.4 15.73 2 12.27 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.77-3.4 7.23-8.55 11.53L12 21.35z"/>
    </svg>
    {% if block.settings.text != blank %}
      <span
        class="wishlist-inspire__icon--text"
        x-text="wishlisted ? '{{ block.settings.text_added }}': '{{ block.settings.text }}'"
      ></span>
    {% endif %}
  </button>
</div>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('wishlist', () => ({
        wishlisted: false,
        appUrl: "https://cabinets-hills-lets-ours.trycloudflare.com",
        addToWishlist(){
          this.wishlisted = !this.wishlisted

          {% unless customer %}
            alert("Please Login to Wishlist the product")
            return;
          {% endunless %}


          const formdata = new FormData();
          formdata.append("customerId", "{{ customer.id }}");
          formdata.append("productId", "{{ product.id }}");
          formdata.append("shop", "{{ shop.permanent_domain }}");

          const requestOptions = {
            method: "POST",
            body: formdata,
            redirect: "follow"
          };

          fetch(`${appUrl}/api/wishlist`, requestOptions)
            .then((response) => response.text())
            .then((result) => console.log(result))
            .catch((error) => console.error(error));

        }
    }))
  })
</script>

{% schema %}
{
  "name": "Wishlist Button",
  "stylesheet": "wishapp.css",
  "javascript": "wishapp.js",
  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "colour",
      "label": "Star Colour",
      "default": "#ff0000"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Wishlist Text Before Added",
      "default": "Add to wishlist"
    },
    {
      "type": "text",
      "id": "text_added",
      "label": "Wishlist Text After Added",
      "default": "Added to wishlist"
    }
  ]
}
{% endschema %}
